---
import { Image } from 'astro:assets';
import carrusel1 from '../assets/images/carrusel/carrusel1.webp';
import carrusel2 from '../assets/images/carrusel/carrusel2.webp';
import carrusel3 from '../assets/images/carrusel/carrusel3.webp';

const images = [carrusel1, carrusel2, carrusel3];
---

<div class="w-full h-screen md:h-full flex-col md:flex-row md:mt-5 flex items-center gap-5">
    <div class="reveal-left w-full h-full md:w-2/3 md:h-4/5 relative overflow-hidden flex items-center justify-center border-b-1 md:border-b-0">
        <!-- Carrusel Container -->
        <div class="carousel-wrapper relative w-full h-full">
            <div class="carousel-track h-full flex transition-transform duration-700 ease-out" id="carouselTrack" style="width: 300%; will-change: transform;">
                {images.map((img, index) => (
                    <div class="carousel-slide w-1/3 h-full shrink-0 flex items-center justify-center">
                        <img
                            src={img.src}
                            alt={`Slide ${index + 1}`}
                            class="w-full h-auto object-cover md:object-contain"
                            alt="Error loading image"
                        />
                    </div>
                ))}
            </div>

            <!-- Indicadores Circulares -->
            <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex gap-3 z-10">
                {images.map((_, index) => (
                    <button
                        class="carousel-indicator w-3 h-3 rounded-full bg-white/70 transition-all duration-200 hover:bg-white cursor-pointer"
                        data-index={index}
                        aria-label={`Go to slide ${index + 1}`}
                        type="button"
                    ></button>
                ))}
            </div>
        </div>
    </div>
    <div class="reveal-right w-full h-full md:w-1/3">
    <div class="flex flex-col md:mt-5 md:p-3 lg:p-10 xl:p-5 max-w-3xl">
            <div class="w-full text-end">
                <span class="ml-2 md:ml-5 font-palatia text-verde-oscuro text-xs md:text-4xl lg:text-5xl xl:text-6xl 2xl:text-7xl">DISEÑADORA</span>
                <span class="font-chopin-light text-amarillo-oscuro ml-2 md:ml-5 text-2xl md:text-4xl lg:text-5xl xl:text-6xl 2xl:text-7xl">GRÁFICA</span>
            </div>
            <span class="mt-5 sm:mt-5 mb-5 md:mb-25 p-3 md:pd-2 md:mx-3 font-libre-franklin-variable text-xs sm:text-xl text-start text-verde-oscuro">
                <p class="mt-5">Construyo sistemas visuales donde la originalidad y la estrategia convergen.  Siendo líder de proyectos, mi prioridad es la funcionalidad y la narrativa visual, hacer que estos elementos reflejen la esencia pura de tu marca, manteniendo siempre un ojo crítico en los detalles finales para asegurar que cada pieza no solo sea estéticamente impecable, sino que cumpla un objetivo comercial claro. Para mí, el diseño es el arte de hacer que la personalidad de una marca sea tangible, memorable y, sobre todo, funcional.</p>
            </span>
        </div>
</div>

<script>
    const track = document.getElementById('carouselTrack') as HTMLElement;
    const indicators = document.querySelectorAll('.carousel-indicator');
    const slides = document.querySelectorAll('.carousel-slide');
    
    let currentIndex = 0;
    const totalSlides = slides.length;
    let autoplayInterval: ReturnType<typeof setInterval>;
    let isAutoPlaying = true;
    let isTransitioning = false;

    // Función para actualizar el carrusel - versión mejorada con loop infinito correcto
    function updateCarousel(index: number, smooth: boolean = true) {
        if (isTransitioning && smooth) return; // Evitar transiciones simultáneas
        
        isTransitioning = smooth;
        
        // Calcular el siguiente índice de forma simple
        let nextIndex = index % totalSlides;
        if (nextIndex < 0) nextIndex += totalSlides;
        
        // Calcular el desplazamiento: (100/totalSlides)% por cada slide
        const slidePercentage = 100 / totalSlides;
        const translateX = -nextIndex * slidePercentage;
        
        if (smooth) {
            track.style.transition = 'transform 0.7s ease-out';
        } else {
            track.style.transition = 'none';
        }
        
        track.style.transform = `translateX(${translateX}%)`;
        currentIndex = nextIndex;

        // Actualizar indicadores
        indicators.forEach((indicator, i) => {
            if (i === currentIndex) {
                indicator.classList.add('bg-white');
                indicator.classList.remove('bg-white/40');
            } else {
                indicator.classList.remove('bg-white');
                indicator.classList.add('bg-white/40');
            }
        });

        if (smooth) {
            setTimeout(() => {
                isTransitioning = false;
            }, 700);
        } else {
            isTransitioning = false;
        }
    }

    // Función para avanzar automáticamente
    function startAutoplay() {
        if (isAutoPlaying && !isTransitioning) {
            autoplayInterval = setInterval(() => {
                updateCarousel(currentIndex + 1, true);
            }, 4000); // Cambia cada 4 segundos
        }
    }

    // Pausar autoplay cuando el usuario interactúa
    function pauseAutoplay() {
        clearInterval(autoplayInterval);
        isAutoPlaying = true;
        setTimeout(startAutoplay, 6000); // Reinicia después de 6 segundos
    }

    // Event listeners para indicadores
    indicators.forEach((indicator) => {
        indicator.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            const dataIndex = target.getAttribute('data-index');
            if (dataIndex !== null && !isTransitioning) {
                const index = parseInt(dataIndex, 10);
                updateCarousel(index, true);
                pauseAutoplay();
            }
        });
    });

    // Inicializar en el siguiente tick para asegurar que el DOM está listo
    setTimeout(() => {
        updateCarousel(0, false); // Inicia sin animación
        startAutoplay();
    }, 100);

    // Pausa al pasar el mouse
    const wrapper = document.querySelector('.carousel-wrapper');
    if (wrapper) {
        wrapper.addEventListener('mouseenter', () => {
            isAutoPlaying = false;
            clearInterval(autoplayInterval);
        });
        wrapper.addEventListener('mouseleave', () => {
            isAutoPlaying = true;
            startAutoplay();
        });
    }
</script>

<style>
    .carousel-track {
        will-change: transform;
    }

    .carousel-indicator {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .carousel-indicator:hover {
        transform: scale(1.2);
    }
</style>