---
import img1 from '../assets/images/infinite-carrusel/1.webp';
import img2 from '../assets/images/infinite-carrusel/2.webp';
import img3 from '../assets/images/infinite-carrusel/3.webp';
import img4 from '../assets/images/infinite-carrusel/4.webp';
import img5 from '../assets/images/infinite-carrusel/5.webp';

const images = [img1, img2, img3, img4, img5];
// Duplicamos las imágenes para crear el efecto infinito seamless
const doubledImages = [...images, ...images];
---

<div class="reveal w-full mt-10 overflow-hidden">
    <div class="infinite-scroll-container w-full">
        <div class="infinite-scroll-track flex">
            {doubledImages.map((img, index) => (
                <div class="infinite-scroll-slide flex-shrink-0" style="width: 100%; aspect-ratio: auto;">
                    <img
                        src={img.src}
                        alt={`Slide ${(index % images.length) + 1}`}
                        class="w-full h-full px-2 md:px-3 object-cover"
                    />
                </div>
            ))}
        </div>
    </div>
</div>

<style>
    .infinite-scroll-container {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .infinite-scroll-track {
        display: flex;
        /* no fixed width; the track will size itself to the total
           width of the slides. after duplicating the images the
           scrollWidth will naturally be twice the container width,
           so calculating `half = track.scrollWidth / 2` continues to
           work perfectly. removing the hardcoded 200% prevents the
           extra empty region that was appearing when the slides
           didn’t actually fill that space. */
        will-change: transform;
    }

    .infinite-scroll-slide {
        /* each slide takes one fifth of the visible area (20%). with
           five unique images duplicated to ten slides, the content
           width becomes exactly two container widths, ensuring there
           is no gap as the track rolls. */
        flex: 0 0 40%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .infinite-scroll-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (min-width:768px){
        .infinite-scroll-slide {
            flex: 0 0 20%;
        }
    }

    /* animation replaced with JS-driven transform; keyframes
       no longer required */

</style>

<script>
  window.addEventListener('load', () => {
    const track = document.querySelector<HTMLElement>('.infinite-scroll-track') || null;

    if (!track) return;

    let offset = 0;
    const isMobile = window.innerWidth < 768;
    let speed = isMobile ? 0.8 : 2.5;
    let running = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          running = entry.isIntersecting;
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(track);

    function step() {
      if (running) {
        offset += speed;

        const half = track.scrollWidth / 2;
        if (offset >= half) offset -= half;

        track.style.transform = `translateX(-${offset}px)`;
      }

      requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  });
</script>
